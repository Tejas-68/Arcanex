<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_neumorph_card_flat"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="16dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_student_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Student"
        android:textAppearance="@style/TextAppearance.ProCollegia.Subheading"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Items"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@+id/tv_student_name" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_items">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_deny"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:textColor="@color/accent_red"
            android:text="Deny"
            android:textAllCaps="false"
            android:background="@drawable/sel_neumorph_button" />
            
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_approve"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:textColor="@color/accent_green"
            android:background="@drawable/sel_neumorph_button"
            android:text="Approve"
            android:textAllCaps="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
