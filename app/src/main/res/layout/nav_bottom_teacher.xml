<?xml version="1.0" encoding="utf-8"?>
<!--
    Teacher Bottom Nav — 5 tabs: Dashboard | Attendance | Leaves | Marks | Profile
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_neumorph_pill"
    android:elevation="8dp">

    <!-- Dashboard / Home -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_home_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_home"
            android:tint="@color/accent_blue" />
        <TextView
            android:id="@+id/nav_home_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Dashboard"
            android:textSize="10sp"
            android:textColor="@color/accent_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Attendance -->
    <LinearLayout
        android:id="@+id/nav_attendance"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_attendance_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_attendance"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_attendance_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Attendance"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Leave Requests -->
    <LinearLayout
        android:id="@+id/nav_leaves"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_leaves_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_leaves"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_leaves_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Leaves"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Marks -->
    <LinearLayout
        android:id="@+id/nav_marks"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_marks_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_marks"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_marks_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Marks"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_profile_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_profile"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_profile_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

</LinearLayout>
