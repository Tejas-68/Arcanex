<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_neumorph_circle_raised"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Honor Score"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- GAUGE CARD -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_neumorph_raised"
                android:paddingBottom="24dp"
                android:layout_marginBottom="16dp">

                <!-- Simple semi-circle gauge representation using an arc progress -->
                <!-- We will use a ProgressBar with a custom drawable and rotation, or just build it with views -->
                <ProgressBar
                    android:id="@+id/pb_honor_gauge"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="32dp"
                    android:progressDrawable="@drawable/circular_progress"
                    android:indeterminate="false"
                    android:max="1000"
                    android:progress="720"
                    android:rotation="-180"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Cover the bottom half of the circle to make it a semi-circle gauge -->
                <View
                    android:layout_width="180dp"
                    android:layout_height="90dp"
                    android:background="@color/neumorph_bg"
                    app:layout_constraintBottom_toBottomOf="@+id/pb_honor_gauge"
                    app:layout_constraintStart_toStartOf="@+id/pb_honor_gauge"
                    app:layout_constraintEnd_toEndOf="@+id/pb_honor_gauge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/pb_honor_gauge"
                    app:layout_constraintStart_toStartOf="@+id/pb_honor_gauge"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1000"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@+id/pb_honor_gauge"
                    app:layout_constraintEnd_toEndOf="@+id/pb_honor_gauge"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tv_honor_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="720"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="40sp"
                    app:layout_constraintBottom_toBottomOf="@+id/pb_honor_gauge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="-10dp" />

                <TextView
                    android:id="@+id/tv_honor_tier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gold_tier_badge"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="⭐ GOLD TIER"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@+id/tv_honor_score"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 6-MONTH HISTORY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neumorph_raised"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6-Month History"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <!-- Mockup of a line chart using simple views, since we don't have MPAndroidChart -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp">
                    
                    <!-- Background gradient for chart -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_chart_gradient" />

                    <!-- We will just put a placeholder text here if we don't have a real chart lib -->
                    <!-- Real implementation would use Canvas or a library -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(Chart Area)"
                        android:textColor="@color/text_muted"
                        android:layout_gravity="center" />
                        
                    <!-- X-Axis Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="bottom"
                        android:paddingHorizontal="10dp"
                        android:layout_marginBottom="-20dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sep" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Oct" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nov" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dec" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jan" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Feb" android:textColor="@color/text_secondary" android:textSize="11sp" android:gravity="center" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- RECENT EVENTS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_neumorph_raised"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Events"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <!-- We will put a RecyclerView here for the events -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_honor_events"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

