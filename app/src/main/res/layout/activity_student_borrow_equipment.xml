<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_bg">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/iv_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="@drawable/bg_neumorph_circle_raised"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="←"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary" />
                </LinearLayout>


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Borrow Equipment"
                    android:textAppearance="@style/TextAppearance.ProCollegia.Heading"
                    android:textSize="22sp" />
            </LinearLayout>

            <!-- Section: Select Equipment -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT EQUIPMENT"
                android:textAppearance="@style/TextAppearance.ProCollegia.Label"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/card_equipment_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_neumorph_raised"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinner_equipment"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
            </LinearLayout>

            <!-- Section: Quantity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTITY"
                android:textAppearance="@style/TextAppearance.ProCollegia.Label"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_neumorph_raised"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="—"
                    android:textSize="18sp"
                    android:padding="0dp"
                    style="@style/ProCollegia.Button.Primary" />

                <TextView
                    android:id="@+id/tv_qty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/btn_plus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:padding="0dp"
                    style="@style/ProCollegia.Button.Primary" />
            </LinearLayout>

            <!-- Section: Purpose -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PURPOSE"
                android:textAppearance="@style/TextAppearance.ProCollegia.Label"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_purpose"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Describe the purpose of borrowing..."
                android:padding="14dp"
                android:background="@drawable/bg_neumorph_inset"
                android:gravity="top"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp" />

            <!-- Section: Return Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPECTED RETURN DATE"
                android:textAppearance="@style/TextAppearance.ProCollegia.Label"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_pick_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Return Date"
                android:textAllCaps="false"
                android:backgroundTint="@color/neumorph_bg"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"
                style="@style/ProCollegia.Button.Primary" />

            <!-- Submit Button -->
            <Button
                android:id="@+id/btn_submit_request"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Submit Request"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                style="@style/ProCollegia.Button.Primary" />

        </LinearLayout>
    </ScrollView>

