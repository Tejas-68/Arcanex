<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_bg">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Account"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_neumorph_tab_container"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <TextView
            android:id="@+id/tabPersonal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Personal"
            android:textStyle="bold"
            android:textColor="@color/text_on_accent"
            android:background="@drawable/bg_neumorph_tab_active" />

        <TextView
            android:id="@+id/tabAcademic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Academic"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tabContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Personal Layout -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="I am a:"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerRole"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    android:entries="@array/role_array" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Full Name"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Phone Number"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:inputType="phone"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Email"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etRegPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Password"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:inputType="textPassword"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Next"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent"
                    android:background="@drawable/bg_neumorph_button" />
                
                <TextView
                    android:id="@+id/tvBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? Login"
                    android:textColor="@color/accent_blue"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="24dp"
                    android:padding="8dp" />
            </LinearLayout>
        </ScrollView>

        <!-- Academic Layout -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <EditText
                    android:id="@+id/etUucms"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="UUCMS ID (for students only)"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etCourse"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Course (BCA, BBA...)"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Year:"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerYear"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    android:entries="@array/year_array" />
                    
                <EditText
                    android:id="@+id/etSem"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_neumorph_input"
                    android:paddingHorizontal="16dp"
                    android:hint="Semester"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:inputType="number"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    
                    <Button
                        android:id="@+id/btnPrev"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Back"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/neumorph_bg_dark"
                        android:textColor="@color/text_primary" />
                        
                    <Button
                        android:id="@+id/btnSubmit"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Register"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/text_on_accent"
                        android:background="@drawable/bg_neumorph_button" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/accent_blue" />
            </LinearLayout>
        </ScrollView>

    </ViewFlipper>

</androidx.constraintlayout.widget.ConstraintLayout>
