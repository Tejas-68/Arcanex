<?xml version="1.0" encoding="utf-8"?>
<!--
    PT Admin Bottom Nav — 5 tabs: Dashboard | Attendance | Equipment | Tournament | Profile
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_neumorph_pill"
    android:elevation="8dp">

    <!-- Dashboard -->
    <LinearLayout
        android:id="@+id/nav_dashboard"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_dashboard_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_dashboard"
            android:tint="@color/accent_blue" />
        <TextView
            android:id="@+id/nav_dashboard_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Dashboard"
            android:textSize="10sp"
            android:textColor="@color/accent_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Attendance -->
    <LinearLayout
        android:id="@+id/nav_attendance"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_attendance_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_attendance"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_attendance_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Attendance"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Equipment / Inventory -->
    <LinearLayout
        android:id="@+id/nav_equipments"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_equipments_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_equipment"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_equipments_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Equipment"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Tournaments -->
    <LinearLayout
        android:id="@+id/nav_tournaments"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_tournaments_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_tournament"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_tournaments_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Tourn."
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_profile_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_profile"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_profile_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

</LinearLayout>
