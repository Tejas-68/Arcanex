<?xml version="1.0" encoding="utf-8"?>
<!--
    Single row in the scanned student log inside BarcodeScannerActivity.
    Shows: ✅ icon | student name + roll number | timestamp
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- Status dot (green → present) -->
    <View
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="#FF48BB78"
        android:layout_marginEnd="12dp" />

    <!-- Name + roll number -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_scanned_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_scanned_roll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll: —"
            android:textColor="#FFAAAAAA"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_scanned_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textColor="#FF4A90D9"
        android:textSize="11sp" />

</LinearLayout>
