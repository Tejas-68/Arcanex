<?xml version="1.0" encoding="utf-8"?>
<!--
    Student Bottom Nav — 5 tabs: Home | Academics | Sports | Alerts | Profile
    Active tab: accent_blue tint set via BottomNavigationHelper
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal"
    android:background="@drawable/bg_neumorph_pill"
    android:elevation="8dp">

    <!-- Home -->
    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_home_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_home"
            android:tint="@color/accent_blue" />
        <TextView
            android:id="@+id/nav_home_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Home"
            android:textSize="10sp"
            android:textColor="@color/accent_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Academics -->
    <LinearLayout
        android:id="@+id/nav_academics"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_academics_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_academics"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_academics_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Academics"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Sports -->
    <LinearLayout
        android:id="@+id/nav_sports"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_sports_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_sports"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_sports_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Sports"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Alerts -->
    <LinearLayout
        android:id="@+id/nav_alerts"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_alerts_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_alerts"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_alerts_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Alerts"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Profile -->
    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">
        <ImageView
            android:id="@+id/nav_profile_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_profile"
            android:tint="@color/text_secondary" />
        <TextView
            android:id="@+id/nav_profile_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

</LinearLayout>
