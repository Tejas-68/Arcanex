<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <!-- Icon: Up arrow or Down arrow based on points -->
    <LinearLayout
        android:id="@+id/ll_event_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/bg_neumorph_circle_raised"
        android:gravity="center">
        <TextView
            android:id="@+id/tv_event_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↑"
            android:textColor="@color/accent_green"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_event_pts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="+ 10 pts"
        android:textColor="@color/accent_green"
        android:textStyle="bold"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" — "
        android:textColor="@color/text_muted" />

    <TextView
        android:id="@+id/tv_event_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Good Conduct"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_event_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Feb 20"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

</LinearLayout>
