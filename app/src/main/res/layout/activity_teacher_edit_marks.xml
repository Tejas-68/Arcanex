<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neumorph_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_neumorph_circle_raised"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="20sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Edit Internal Marks"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
            
        <ImageView
            android:id="@+id/iv_cloud_sync"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/stat_sys_upload_done"
            app:tint="@color/text_secondary"
            android:padding="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@+id/btn_submit_marks">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- 3 Spinners Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_neumorph_pill"
                    android:paddingHorizontal="8dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_vertical">
                    <Spinner
                        android:id="@+id/spinner_section"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/neumorph_bg"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:background="@drawable/bg_neumorph_pill"
                    android:paddingHorizontal="8dp"
                    android:layout_marginHorizontal="6dp"
                    android:gravity="center_vertical">
                    <Spinner
                        android:id="@+id/spinner_subject"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/neumorph_bg"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8"
                    android:background="@drawable/bg_neumorph_pill"
                    android:paddingHorizontal="8dp"
                    android:layout_marginStart="6dp"
                    android:gravity="center_vertical">
                    <Spinner
                        android:id="@+id/spinner_exam"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/neumorph_bg"
                        android:spinnerMode="dropdown"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Spreadsheet Neumorphic Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_neumorph_raised">

                <!-- Top Save Indicator inside card -->
                <TextView
                    android:id="@+id/tv_save_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ All changes saved"
                    android:textColor="@color/accent_green"
                    android:textSize="11sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Table Header Grid Row -->
                <LinearLayout
                    android:id="@+id/table_header"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="32dp"
                    android:baselineAligned="false"
                    app:layout_constraintTop_toTopOf="parent">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.5"
                        android:text="Student"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="IA-1"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="IA-2"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Assign."
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />
                </LinearLayout>

                <!-- Students RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_students"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintTop_toBottomOf="@id/table_header" />

                <!-- Sticky Class Avg Footer inside the card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#FAFAFA"
                    app:layout_constraintTop_toBottomOf="@id/rv_students"
                    app:layout_constraintBottom_toBottomOf="parent">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.5"
                        android:text="Class Avg"
                        android:textStyle="italic"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center_vertical|end"
                        android:paddingEnd="12dp"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:id="@+id/tv_avg_ia1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="0.0"
                        android:textStyle="italic"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:id="@+id/tv_avg_ia2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="0.0"
                        android:textStyle="italic"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />

                    <TextView
                        android:id="@+id/tv_avg_assign"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="0.0"
                        android:textStyle="italic"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/table_cell_border" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Loading label -->
            <TextView
                android:id="@+id/tv_student_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No students loaded"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="20dp"/>

        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_submit_marks"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:text="Finalize Marks"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_primary"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav" />

    <include layout="@layout/loading_overlay" />

    <include

</androidx.constraintlayout.widget.ConstraintLayout>
