<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base surface background -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_bg" />
        </shape>
    </item>

    <!-- Inner Shadow Dark (Top-Left) -->
    <item
        android:bottom="2dp"
        android:right="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_shadow_dark"/>
        </shape>
    </item>

    <!-- Inner Shadow Light (Bottom-Right) -->
    <item
        android:left="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_shadow_light"/>
        </shape>
    </item>

    <!-- Fill -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/neumorph_bg_dark" />
        </shape>
    </item>
</layer-list>
